# ─── App ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_DOMAIN=tatomir.app
NEXT_PUBLIC_APP_URL=https://tatomir.app

# For Docker: set to "standalone" — leave empty for Vercel/Railway/Render
NEXT_OUTPUT=

# ─── Database ─────────────────────────────────────────────────────────
# Supported providers: postgresql | mysql | sqlite
DATABASE_PROVIDER=postgresql

# PostgreSQL (Neon, Supabase, Railway, self-hosted)
DATABASE_URL=postgresql://user:password@localhost:5432/tatomir

# MySQL (PlanetScale, Railway, self-hosted)
# DATABASE_PROVIDER=mysql
# DATABASE_URL=mysql://user:password@localhost:3306/tatomir

# SQLite — local dev only
# DATABASE_PROVIDER=sqlite
# DATABASE_URL=file:./tatomir.db

# ─── Auth (admin users) ───────────────────────────────────────────────
NEXTAUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000
# Sprint S1: env-var admin credentials (no DB needed). Sprint S2 switches to DB + bcrypt.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Media Storage ────────────────────────────────────────────────────
# Supported: uploadthing | supabase | vercel-blob | minio | s3
STORAGE_PROVIDER=uploadthing

# Uploadthing
UPLOADTHING_SECRET=
UPLOADTHING_APP_ID=

# Supabase Storage (when DATABASE_PROVIDER=postgresql with Supabase)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# MinIO / S3-compatible (self-hosted)
# S3_ENDPOINT=http://localhost:9000
# S3_BUCKET=tatomir
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_PUBLIC_URL=http://localhost:9000/tatomir

# Vercel Blob
# BLOB_READ_WRITE_TOKEN=

# ─── Email ────────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@tatomir.app

# ─── Cache (optional — improves multi-instance deployments) ───────────
# Leave empty to use in-memory cache (works fine for single instance)
# Set to Redis URL for distributed cache across multiple instances
# Works on Railway, Fly.io, Render, or any platform with Redis
REDIS_URL=

# ─── Cron (scheduled publish) ─────────────────────────────────────────
# Secure the /api/cron/publish endpoint
# Any platform can call: GET /api/cron/publish?secret=YOUR_SECRET
CRON_SECRET=change-me-generate-random-secret

# Vercel Cron (vercel.json handles this — no env var needed on Vercel)
# Railway / Render / Fly.io: configure an HTTP cron to call the endpoint above
# Self-hosted: add a crontab entry:
#   * * * * * curl -s "http://localhost:3000/api/cron/publish?secret=YOUR_SECRET"

# ─── Localisation ────────────────────────────────────────────────────
SUPPORTED_LOCALES=en,fr,es,de,pt,ja,zh
DEFAULT_LOCALE=en

# ─── Internal ────────────────────────────────────────────────────────
NODE_ENV=development
